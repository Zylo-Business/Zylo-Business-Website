# ---- Zylo Tech Webinar backend configuration ----
# Copy this file to ".env" and fill in your real values.

# Server
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000

# Webinar details (single source of truth — the landing page reads these)
WEBINAR_TITLE=Wealth & Opportunity Master Class 2026
WEBINAR_DATE_ISO=2026-07-17T19:00:00Z
WEBINAR_DATE_LABEL=July 17–20, 2026 (Fri–Mon)
WEBINAR_TIME_LABEL=7:00 PM GMT daily
WEBINAR_LOCATION=Online via Zoom
WEBINAR_ZOOM_LINK=https://zoom.us/j/PLACEHOLDER
REGISTER_PHONE=0543907751

# Pricing (GHS). Set PRICE_GHS=0 to run in free lead-generation mode (no payment).
PRICE_GHS=200
CURRENCY=GHS

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Zylo Tech Solutions <hello@zylotech.com>
REPLY_TO_EMAIL=hello@zylotech.com

# Admin (protects the leads list / CSV export). Change this to a long random string.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Local testing only: set to "true" to simulate a successful payment WITHOUT calling
# Paystack (lets you test the whole flow before you have live keys). MUST be false/blank
# in production.
DEV_FAKE_PAYMENTS=false
