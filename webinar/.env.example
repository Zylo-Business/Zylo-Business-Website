# ---- Zylo Tech Webinar backend configuration ----
# Copy this file to ".env" and fill in your real values.

# Server
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000

# Webinar details (single source of truth — the landing page reads these)
WEBINAR_TITLE=Wealth & Opportunity Master Class 2026
WEBINAR_DATE_ISO=2026-07-24T19:00:00Z
WEBINAR_DATE_LABEL=July 24–27, 2026 (Fri–Mon)
WEBINAR_TIME_LABEL=7:00 PM GMT daily
WEBINAR_LOCATION=Online via Zoom
WEBINAR_ZOOM_LINK=https://zoom.us/j/PLACEHOLDER
# Your real business number. Set this in .env (never committed) — it is served to the
# browser only in an obfuscated form, never as plain text.
REGISTER_PHONE=0245426025

# Pricing (GHS). Set PRICE_GHS=0 to run in free lead-generation mode (no payment).
PRICE_GHS=200
CURRENCY=GHS

# Hubtel Online Checkout (https://developers.hubtel.com). From your Hubtel dashboard:
#   API ID  = Basic-auth username, API Key = Basic-auth password (API Keys section)
#   MERCHANT_ACCOUNT = your POS Sales / Merchant Account Number (required)
HUBTEL_API_ID=xxxxxxxx
HUBTEL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUBTEL_MERCHANT_ACCOUNT=

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Zylo Tech Solutions <hello@zylotech.com>
REPLY_TO_EMAIL=hello@zylotech.com

# Airtable — the CRM / source of record. Every registration is mirrored here.
# See README for the table schema.
# Create a Personal Access Token at https://airtable.com/create/tokens (scopes: data.records:write)
AIRTABLE_API_KEY=patxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_NAME=Registrations

# Admin (protects the leads list / CSV export). Change this to a long random string.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Local testing only: set to "true" to simulate a successful payment WITHOUT calling
# Hubtel (lets you test the whole flow before you have live keys). MUST be false/blank
# in production.
DEV_FAKE_PAYMENTS=false
